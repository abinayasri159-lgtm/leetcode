class Solution {

    public boolean isPowerOfTwo(int n) {

        // Power of two must be greater than 0
        if (n <= 0) {
            return false;
        }

        // Keep dividing by 2 until n becomes odd
        while (n % 2 == 0) {
            n = n / 2;
        }

        // If the final value is 1, then it is a power of two
        if (n == 1) {
            return true;
        } else {
            return false;
        }
    }
}
